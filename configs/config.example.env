ENVIRONMENT=local
SERVICE_NAME=genworker
RUNTIME_PROFILE=local
HTTP_HOST=127.0.0.1
HTTP_PORT=8000
LOG_DIR=logs
REDIS_ENABLED=false
MYSQL_ENABLED=false
OPENVIKING_ENABLED=false
IM_CHANNEL_ENABLED=false

# LiteLLM local/dev template
LITELLM_DEFAULT_MODEL=provider/model-name
LITELLM_DEFAULT_API_BASE=https://your-provider.example/v1
LITELLM_DEFAULT_API_KEY=replace-me
